<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Internet permission for local server -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application>
        <!--
            BootstrapShimProvider attaches the JVMTI agent and adds the
            dta-sidekick-shim jar to the bootstrap classpath. android:initOrder
            is set higher than InitializationProvider's default (0) so this
            provider runs first — by the time AndroidX Startup verifies
            SidekickInitializer, the shim's HookDispatcher / HookRegistry /
            MethodHook are already resolvable from the bootstrap classloader.
            Without this ordering, class-link of SidekickInitializer NCDFEs
            and the host app crashes on launch.
        -->
        <provider
            android:name="io.yamsergey.dta.sidekick.init.BootstrapShimProvider"
            android:authorities="${applicationId}.dta-sidekick-bootstrap"
            android:exported="false"
            android:initOrder="1000" />

        <!-- AndroidX Startup Initializer -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="io.yamsergey.dta.sidekick.init.SidekickInitializer"
                android:value="androidx.startup" />
        </provider>
    </application>

</manifest>
