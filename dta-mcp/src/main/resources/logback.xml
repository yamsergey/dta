<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- MCP servers MUST NOT log to stdout - it's reserved for JSON-RPC -->
    <appender name="STDERR" class="ch.qos.logback.core.ConsoleAppender">
        <target>System.err</target>
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- File appender - active when -Ddta.log.file is set, otherwise writes to /dev/null -->
    <appender name="FILE" class="ch.qos.logback.core.FileAppender">
        <file>${dta.log.file:-/dev/null}</file>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Suppress verbose MCP SDK logging -->
    <logger name="io.modelcontextprotocol" level="WARN"/>

    <root level="${dta.log.level:-INFO}">
        <appender-ref ref="STDERR"/>
        <appender-ref ref="FILE"/>
    </root>
</configuration>
